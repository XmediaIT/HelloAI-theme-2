{
  "description": "Centered hero block with bold uppercase title and orange overlay over an image.",
  "goals": [
    "Keep text short and high-contrast",
    "Preserve a single static hero layout",
    "Prioritize readability over the image"
  ],
  "image": {
    "allowedModes": [
      "keep",
      "suggest",
      "library",
      "generate",
      "manual"
    ],
    "preferredMode": "suggest",
    "subjectHints": [
      "people at work",
      "team collaboration",
      "modern workspace",
      "neutral lifestyle"
    ]
  },
  "fieldGuidance": {
    "eyebrow": "3-8 words, sentence case.",
    "title": "4-10 words, strong uppercase headline.",
    "button.label": "1-3 words, clear action verb."
  },
  "runtimeContextInputs": [
    "industry",
    "brandTone",
    "targetAudience",
    "pageGoal",
    "language"
  ],
  "allowedActions": [
    "rewrite_text",
    "shorten_text",
    "expand_text",
    "tone_adjust",
    "translate_text"
  ],
  "constraints": {
    "contentOnly": true,
    "preserveStructure": true,
    "preserveClasses": true,
    "preserveEditorHooks": true
  }
}
