{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "HeroFeatureSplitStats.schema.json",
  "title": "HeroFeatureSplitStats",
  "type": "object",
  "required": ["hero", "title", "text", "features", "cta", "contact", "stats"],
  "properties": {
    "hero": {
      "type": "object",
      "required": ["image"],
      "properties": {
        "image": {
          "type": "object",
          "required": ["src", "alt", "mode"],
          "properties": {
            "src": { "type": "string", "minLength": 1 },
            "alt": { "type": "string", "minLength": 1 },
            "mode": { "type": "string", "enum": ["keep", "suggest", "library", "generate", "manual"] }
          }
        }
      }
    },
    "title": { "type": "string", "minLength": 1 },
    "text": { "type": "string", "minLength": 1 },
    "features": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["icon", "title", "text"],
        "properties": {
          "icon": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "text": { "type": "string", "minLength": 1 }
        }
      }
    },
    "cta": {
      "type": "object",
      "required": ["label", "url"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "url": { "type": "string", "minLength": 1 },
        "target": { "type": "string", "enum": ["_self", "_blank"] }
      }
    },
    "contact": {
      "type": "object",
      "required": ["icon", "label", "phone"],
      "properties": {
        "icon": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "phone": { "type": "string", "minLength": 1 }
      }
    },
    "stats": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["value", "label"],
        "properties": {
          "value": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
