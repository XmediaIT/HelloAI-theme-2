{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "VehiclesServicedSplit.schema.json",
  "title": "VehiclesServicedSplit",
  "type": "object",
  "required": [
    "leftIntro",
    "services",
    "stats",
    "rightIntro",
    "images",
    "featurePanel"
  ],
  "properties": {
    "leftIntro": {
      "type": "object",
      "required": [
        "eyebrow",
        "text"
      ],
      "properties": {
        "eyebrow": {
          "type": "string",
          "minLength": 1
        },
        "text": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "services": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "required": [
          "icon",
          "title",
          "text"
        ],
        "properties": {
          "icon": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "text": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "stats": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {
        "type": "object",
        "required": [
          "value",
          "label"
        ],
        "properties": {
          "value": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "rightIntro": {
      "type": "object",
      "required": [
        "eyebrow",
        "heading"
      ],
      "properties": {
        "eyebrow": {
          "type": "string",
          "minLength": 1
        },
        "heading": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "images": {
      "type": "object",
      "required": [
        "primary",
        "secondary",
        "badgeValue",
        "badgeLine1",
        "badgeLine2"
      ],
      "properties": {
        "primary": {
          "$ref": "#/$defs/imageAsset"
        },
        "secondary": {
          "$ref": "#/$defs/imageAsset"
        },
        "badgeValue": {
          "type": "string",
          "minLength": 1
        },
        "badgeLine1": {
          "type": "string",
          "minLength": 1
        },
        "badgeLine2": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "featurePanel": {
      "type": "object",
      "required": [
        "eyebrow",
        "text",
        "columns"
      ],
      "properties": {
        "eyebrow": {
          "type": "string",
          "minLength": 1
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "columns": {
          "type": "array",
          "minItems": 3,
          "maxItems": 3,
          "items": {
            "type": "object",
            "required": [
              "items"
            ],
            "properties": {
              "items": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "imageAsset": {
      "type": "object",
      "required": [
        "src",
        "alt",
        "mode"
      ],
      "properties": {
        "src": {
          "type": "string",
          "minLength": 1
        },
        "alt": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "enum": [
            "keep",
            "suggest",
            "library",
            "generate",
            "manual"
          ]
        }
      }
    }
  }
}
