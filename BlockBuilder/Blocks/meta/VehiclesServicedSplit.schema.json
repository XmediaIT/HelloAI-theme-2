{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "VehiclesServicedSplit.schema.json",
  "title": "VehiclesServicedSplit",
  "type": "object",
  "required": [
    "image",
    "heading",
    "description",
    "items",
    "button"
  ],
  "properties": {
    "image": {
      "type": "object",
      "required": [
        "src",
        "alt",
        "mode"
      ],
      "properties": {
        "src": {
          "type": "string",
          "minLength": 1
        },
        "alt": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "enum": [
            "keep",
            "suggest",
            "library",
            "generate",
            "manual"
          ]
        }
      }
    },
    "heading": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "items": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "required": [
          "icon",
          "text"
        ],
        "properties": {
          "icon": {
            "type": "string",
            "minLength": 1
          },
          "text": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "button": {
      "type": "object",
      "required": [
        "label",
        "url"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "enum": [
            "_self",
            "_blank"
          ]
        }
      }
    }
  }
}
