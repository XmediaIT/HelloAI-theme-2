{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "FeatureImageChecklist.schema.json",
  "title": "FeatureImageChecklist",
  "type": "object",
  "required": [
    "image",
    "promoCard",
    "content",
    "listItems",
    "callInfo"
  ],
  "properties": {
    "image": {
      "type": "object",
      "required": [
        "src",
        "alt",
        "mode"
      ],
      "properties": {
        "src": {
          "type": "string",
          "minLength": 1
        },
        "alt": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "enum": [
            "keep",
            "suggest",
            "library",
            "generate",
            "manual"
          ]
        }
      }
    },
    "promoCard": {
      "type": "object",
      "required": [
        "icon",
        "title"
      ],
      "properties": {
        "icon": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "content": {
      "type": "object",
      "required": [
        "title",
        "eyebrow",
        "text",
        "button"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "eyebrow": {
          "type": "string",
          "minLength": 1
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "button": {
          "type": "object",
          "required": [
            "label",
            "url"
          ],
          "properties": {
            "label": {
              "type": "string",
              "minLength": 1
            },
            "url": {
              "type": "string",
              "minLength": 1
            },
            "target": {
              "type": "string",
              "enum": [
                "_self",
                "_blank"
              ]
            }
          }
        }
      }
    },
    "listItems": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "text"
        ],
        "properties": {
          "text": {
            "type": "string",
            "minLength": 1
          },
          "icon": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "callInfo": {
      "type": "object",
      "required": [
        "label",
        "phone"
      ],
      "properties": {
        "icon": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "phone": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
